#!/bin/bash
set -euo pipefail

DEVICE="$1"
MOUNT_POINT="/mnt/ipod"
PYTHON_SCRIPT="/opt/sync_ipod/sync_ipod.py"

mkdir -p "$MOUNT_POINT"

if mountpoint -q "$MOUNT_POINT"; then
    exit 0
fi

sleep 2

mount -t vfat -o rw,utf8=1,shortname=mixed "$DEVICE" "$MOUNT_POINT"

cleanup() {
    sync || true
    umount "$MOUNT_POINT" || true
}
trap cleanup EXIT

python3 "$PYTHON_SCRIPT" "$MOUNT_POINT"
